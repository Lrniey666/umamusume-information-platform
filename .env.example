# ═══════════════════════════════════════════
# 賽馬娘輿情分析平台 — 環境變數範本
# 複製此檔案為 .env 並填入真實金鑰
# ═══════════════════════════════════════════

# ── AI API 金鑰 ──────────────────────────────
# Google Gemini（取得：https://aistudio.google.com/app/apikey）
GEMINI_API_KEY=AIzaSy...你的Gemini金鑰

# Anthropic Claude（取得：https://console.anthropic.com/settings/keys）
ANTHROPIC_API_KEY=sk-ant-api03-...你的Claude金鑰

# ── Django 設定 ──────────────────────────────
# 隨機長字串（可用 python -c "import secrets; print(secrets.token_hex(50))" 生成）
DJANGO_SECRET_KEY=請替換為隨機長字串

# 本地開發設 True，正式部署設 False
DJANGO_DEBUG=True

# 允許的 Host（逗號分隔，Docker 部署設 localhost,127.0.0.1）
DJANGO_ALLOWED_HOSTS=*

# ── 資料庫 ───────────────────────────────────
# Docker 部署用 PostgreSQL（docker-compose 已自動帶入，這裡可留空或覆寫）；
# 本機開發不設 DJANGO_DB_ENGINE 即自動使用 SQLite。
#   DJANGO_DB_ENGINE=postgres   # 設為 postgres 才啟用 PostgreSQL，否則 SQLite
#   POSTGRES_HOST=db            # Docker 內為服務名 db；本機連線改 localhost
#   POSTGRES_PORT=5432
POSTGRES_DB=umamusume
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── YouTube Data API（O5）─────────────────────
# Google Cloud Console 取得：https://console.cloud.google.com/apis/credentials
# 啟用 YouTube Data API v3 後建立 API 金鑰
YOUTUBE_API_KEY=AIzaSy...你的YouTube金鑰

# ── Discord Bot 設定（D1-D8）──────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CRAWL_CHANNEL_IDS=channel_id_1,channel_id_2
DISCORD_NEWS_CHANNEL_ID=your_news_channel_id
DISCORD_NEWS_MODEL=gemini
DISCORD_CRAWL_LIMIT=1000
