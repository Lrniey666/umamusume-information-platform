# ============================================================
# .gitignore — 賽馬娘資訊平台 (Uma Musume Information Platform)
# ============================================================

# ------------------------------------------------------------
# [機密] 環境變數與 API 金鑰 — 絕對不可上傳
# ------------------------------------------------------------
.env
.env.*
!.env.example
google_ai_config.json
*_api_key*.json
*_credentials*.json
secrets/

# ------------------------------------------------------------
# Python 快取與編譯產物
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so

# ------------------------------------------------------------
# Django 執行期產物
# ------------------------------------------------------------
*.sqlite3
*.sqlite3-journal
db.sqlite3
db.sqlite3-journal
data/dev_sqlite_dump.json
sqlite_db/
staticfiles/
static_collected/
media/
*.pot

# ------------------------------------------------------------
# 日誌
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# 爬蟲 / Pipeline 資料目錄（體積大、可重新生成）
# ------------------------------------------------------------
data/
dataset/
temp_files/

# ------------------------------------------------------------
# RAG 知識庫與搜尋索引（本機生成，不納入版控）
# ------------------------------------------------------------
knowledge_base/
index/

# ------------------------------------------------------------
# 向量資料庫二進位快取
# ------------------------------------------------------------
*.mmap
*.dat

# ------------------------------------------------------------
# VRM 3D 模型檔（體積過大）
# ------------------------------------------------------------
*.vrm

# ------------------------------------------------------------
# 程序 PID 檔
# ------------------------------------------------------------
*.pid

# ------------------------------------------------------------
# 暫存 / 除錯輸出
# ------------------------------------------------------------
_tmp_*.json
_tmp_*.txt
_*_debug.txt
_*_debug.json

# ------------------------------------------------------------
# Jupyter Notebook
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------
# 虛擬環境
# ------------------------------------------------------------
venv/
.venv/
env/
ENV/
.env_backup/

# ------------------------------------------------------------
# Docker 本機資料卷與建構快取
# ------------------------------------------------------------
.docker/
docker/qdrant_data/

# ------------------------------------------------------------
# 測試與覆蓋率報告
# ------------------------------------------------------------
.coverage
htmlcov/
*.cover
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ------------------------------------------------------------
# IDE / 編輯器設定（不強制團隊共用）
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# 作業系統產生的垃圾檔
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Node（前端套件，若有）
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# 計劃書檔案
# ------------------------------------------------------------

plan/

# ------------------------------------------------------------
# 參考資料
# ------------------------------------------------------------

參考專案/

# ------------------------------------------------------------
# 人物模型資料
# ------------------------------------------------------------

narita-top-road-runtime-config.txt
narita-top-road-vrm-data.txt

